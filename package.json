{
  "name": "webclaudecode",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cloud/web-delivered Claude Code — drive the real Claude Code on your own machine from a browser.",
  "comment": "exFAT drive: NO npm/pnpm workspaces (symlinks unsupported). All deps live HERE in the root node_modules; cross-package imports resolve via aliases (tsconfig paths / vitest / esbuild / vite). See docs/issues/ISSUES.md #8.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json && tsc -p packages/web/tsconfig.json",
    "dev:web": "vite --config packages/web/vite.config.ts",
    "build:web": "vite build --config packages/web/vite.config.ts"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vitest": "^2.1.8"
  }
}
